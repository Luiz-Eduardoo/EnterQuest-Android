<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFF"
    android:fillViewport="true"
    tools:context=".Gerente">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="760dp"
        android:paddingStart="28dp"
        android:paddingTop="24dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="270dp"
            android:layout_height="180dp"
            android:contentDescription="Logo EnterQuest"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_enterquest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtPortalGerente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Portal do Gerente"
            android:textColor="#0097A7"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgLogo" />

        <TextView
            android:id="@+id/txtOlaGerente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:text="Olá 👋"
            android:textColor="#071A33"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtPortalGerente" />

        <TextView
            android:id="@+id/txtPerguntaGerente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="O que você gostaria de fazer?"
            android:textColor="#6B7280"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtOlaGerente" />

        <LinearLayout
            android:id="@+id/cardAcoesGerente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="34dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_card_login"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtPerguntaGerente">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ações do gerente"
                android:textColor="#071A33"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Gerencie chamados, usuários e relatórios"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/btnAbrirChamadoGerente"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button_enterquest"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Abrir Chamado"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnMeusChamadosGerente"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Meus Chamados"
                android:background="@drawable/bg_button_enterquest"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnTodosChamadosGerente"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Todos os Chamados"
                android:background="@drawable/bg_button_enterquest"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCriarUsuarioGerente"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_enterquest"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Criar Usuário"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnAbrirDashboardGerente"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_enterquest"
                android:textColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Abrir Dashboard"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardInfoGerente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="18dp"
            android:background="@drawable/bg_card_soft"
            android:orientation="horizontal"
            android:padding="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardAcoesGerente">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_icon_circle"
                android:padding="10dp"
                android:src="@drawable/ic_support"
                app:tint="#0097A7" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Controle completo"
                    android:textColor="#071A33"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Acompanhe chamados, crie usuários e visualize indicadores do helpdesk."
                    android:textColor="#6B7280"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>