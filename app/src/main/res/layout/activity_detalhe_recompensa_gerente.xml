<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFF"
    android:fillViewport="true"
    tools:context=".DetalheRecompensaGerente">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="760dp"
        android:paddingStart="28dp"
        android:paddingTop="24dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="270dp"
            android:layout_height="180dp"
            android:contentDescription="Logo EnterQuest"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_enterquest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTituloDetalheRecompensa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Gerenciar Recompensa"
            android:textColor="#071A33"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgLogo" />

        <TextView
            android:id="@+id/txtSubtituloDetalheRecompensa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Edite os dados da recompensa ou remova-a da loja."
            android:textColor="#6B7280"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtTituloDetalheRecompensa" />

        <LinearLayout
            android:id="@+id/cardDetalheRecompensa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_login"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSubtituloDetalheRecompensa">

            <EditText
                android:id="@+id/editNomeDetalheRecompensa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="Nome da recompensa"
                android:inputType="text"
                android:padding="14dp" />

            <EditText
                android:id="@+id/editDescricaoDetalheRecompensa"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="14dp"
                android:gravity="top"
                android:hint="Descrição da recompensa"
                android:inputType="textMultiLine"
                android:padding="14dp" />

            <EditText
                android:id="@+id/editCustoDetalheRecompensa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:hint="Custo em pontos"
                android:inputType="number"
                android:padding="14dp" />

            <EditText
                android:id="@+id/editEstoqueDetalheRecompensa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:hint="Estoque disponível"
                android:inputType="number"
                android:padding="14dp" />

            <TextView
                android:id="@+id/btnSalvarAlteracoesRecompensa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_enterquest"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Salvar Alterações"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnExcluirRecompensa"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_enterquest"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Excluir Recompensa"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>