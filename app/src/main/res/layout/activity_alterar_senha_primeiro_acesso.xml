<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFF"
    android:fillViewport="true"
    tools:context=".AlterarSenhaPrimeiroAcesso">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="760dp"
        android:paddingStart="28dp"
        android:paddingTop="32dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="270dp"
            android:layout_height="180dp"
            android:contentDescription="Logo EnterQuest"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_enterquest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTituloTela"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:text="Primeiro acesso"
            android:textColor="#071A33"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgLogo" />

        <TextView
            android:id="@+id/txtSubtituloTela"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Por segurança, altere sua senha provisória antes de continuar."
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtTituloTela" />

        <LinearLayout
            android:id="@+id/cardPrimeiroAcesso"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_card_login"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="22dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSubtituloTela">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nova senha"
                android:textColor="#071A33"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editNovaSenhaPrimeiroAcesso"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_spinner"
                android:hint="Digite sua nova senha"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#071A33"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Confirmar senha"
                android:textColor="#071A33"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editConfirmarSenhaPrimeiroAcesso"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_spinner"
                android:hint="Confirme sua nova senha"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#071A33"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnAlterarSenhaPrimeiroAcesso"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_button_enterquest"
                android:text="Alterar senha"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>