<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_soft"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtNomeResgateAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nome da recompensa"
        android:textColor="#071A33"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDescricaoResgateAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Descrição da recompensa"
        android:textColor="#6B7280"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/txtCodigoResgateAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Código: RES-A7K9P2"
        android:textColor="#071A33"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtStatusResgateAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Status: Pendente de retirada"
        android:textColor="#D97706"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtCustoResgateAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_enterquest"
            android:paddingStart="12dp"
            android:paddingTop="7dp"
            android:paddingEnd="12dp"
            android:paddingBottom="7dp"
            android:text="5 pontos"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDataResgateAdmin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="19/05/2026 às 21:30"
            android:textColor="#0097A7"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/btnConfirmarEntregaResgate"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_enterquest"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Confirmar Entrega"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>