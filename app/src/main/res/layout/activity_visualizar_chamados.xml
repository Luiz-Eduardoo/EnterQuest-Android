<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FBFF"
    android:fillViewport="true"
    tools:context=".VisualizarChamados">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="760dp"
        android:paddingStart="28dp"
        android:paddingTop="24dp"
        android:paddingEnd="28dp"
        android:paddingBottom="36dp">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="270dp"
            android:layout_height="180dp"
            android:contentDescription="Logo EnterQuest"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_enterquest"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txtTituloTela"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Chamados"
            android:textColor="#071A33"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgLogo" />

        <TextView
            android:id="@+id/txtSubtituloTela"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Acompanhe seus chamados abertos e finalizados."
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtTituloTela" />

        <LinearLayout
            android:id="@+id/cardLista"
            android:layout_width="0dp"
            android:layout_height="520dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_login"
            android:elevation="5dp"
            android:orientation="vertical"
            android:padding="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtSubtituloTela">

            <TextView
                android:id="@+id/txtListaTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meus chamados"
                android:textColor="#071A33"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtListaSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Veja o status de cada solicitação"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <ListView
                android:id="@+id/listViewChamados"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="16dp"
                android:background="@android:color/transparent"
                android:cacheColorHint="@android:color/transparent"
                android:divider="#E5E7EB"
                android:dividerHeight="1dp"
                android:listSelector="@android:color/transparent"
                android:padding="0dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>